    "distance = int(input(\"Enter the planned road trip :\"))\n",
    "carAverage = int(input(\"Enter your car's average :\"))\n",
    "fuelprice = float(input (\"Enter the fuel price per liter :\"))\n",
    "totalliter = distance / carAverage\n",
    "cost = fuelprice * totalliter\n",
    "print (totalliter)\n",
    "print (cost)"
